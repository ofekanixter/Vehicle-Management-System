# Application settings
APP_NAME=drivenow
DEBUG=true

# Database settings
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://drivenow:drivenow@localhost:5432/drivenow

# Postgres container settings (used by docker-compose.yml)
POSTGRES_USER=drivenow
POSTGRES_PASSWORD=drivenow
POSTGRES_DB=drivenow

# RabbitMQ broker settings
# Format: amqp://user:password@host:port/
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# RabbitMQ container credentials (used by docker-compose.yml)
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
